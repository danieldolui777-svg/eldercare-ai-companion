{
  "name": "@eldercare/api",
  "version": "0.0.1",
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "dev": "ts-node-dev --respawn --transpile-only -r tsconfig-paths/register src/main.ts",
    "start": "node dist/apps/api/src/main.js",
    "set-password": "tsx prisma/set-password.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src"
  },
  "dependencies": {
    "@eldercare/ai-providers": "workspace:*",
    "@eldercare/config": "workspace:*",
    "@eldercare/domain": "workspace:*",
    "@fastify/static": "^8.0.0",
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/platform-fastify": "^10.0.0",
    "@nestjs/schedule": "^6.1.3",
    "@prisma/client": "^5.16.0",
    "@types/node": "^22.0.0",
    "bcryptjs": "^3.0.3",
    "prisma": "^5.16.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0",
    "typescript": "^5.5.0",
    "ws": "^8.21.0",
    "zod": "^3.23.0"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@types/ws": "^8.18.1",
    "ts-node": "^10.9.0",
    "ts-node-dev": "^2.0.0",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.19.0",
    "vitest": "^2.0.0"
  }
}
