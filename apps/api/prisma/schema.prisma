generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Resident {
  id                String   @id @default(uuid())
  firstName         String
  preferredName     String?
  dateOfBirth       DateTime
  gender            Gender?
  familyContactName     String?
  familyContactRelation String?
  familyContactPhone    String?
  language          String   @default("fr")
  voicePreferences  Json     @default("{}")
  consentStatus     ConsentStatus
  privacySettings   Json
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  medications         Medication[]
  medicationSchedules MedicationSchedule[]
  reminderEvents      ReminderEvent[]
  alerts              Alert[]
  memories            ResidentMemory[]
  conversationEntries ConversationEntry[]
  caregiverLinks      CaregiverResident[]
  deviceTokens        DeviceToken[]
}

// Curated companion memory — distilled, NON-MEDICAL facts the companion may use
// to personalise conversation (e.g. "grandson is called Paul", "was a teacher").
// Deliberately separate from medical/reminder data and audit logs (data
// boundary). Never store diagnoses, medication, or treatment info here.
model ResidentMemory {
  id         String         @id @default(uuid())
  residentId String
  category   MemoryCategory @default(other)
  content    String
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  resident Resident @relation(fields: [residentId], references: [id])

  @@index([residentId])
}

// Verbatim conversation log — OPTIONAL, only written when the resident has
// consented (privacySettings.storeTranscripts). Kept separate from curated
// memory so it can be disabled or purged independently.
model ConversationEntry {
  id         String   @id @default(uuid())
  residentId String
  role       String
  content    String
  createdAt  DateTime @default(now())

  resident Resident @relation(fields: [residentId], references: [id])

  @@index([residentId])
}

model Caregiver {
  id                      String           @id @default(uuid())
  name                    String
  role                    CaregiverRole
  phone                   String?
  email                   String           @unique
  passwordHash            String?
  notificationPreferences Json
  createdAt               DateTime         @default(now())
  updatedAt               DateTime         @updatedAt

  assignedAlerts Alert[]
  residentLinks  CaregiverResident[]
}

// Which residents a caregiver may access. Admins bypass this (see AuthZ).
model CaregiverResident {
  caregiverId String
  residentId  String
  createdAt   DateTime @default(now())

  caregiver Caregiver @relation(fields: [caregiverId], references: [id], onDelete: Cascade)
  resident  Resident  @relation(fields: [residentId], references: [id], onDelete: Cascade)

  @@id([caregiverId, residentId])
  @@index([residentId])
}

// A provisioned device bound to ONE resident. The raw token is shown once at
// pairing; only its hash is stored. The device sends the token to authenticate.
model DeviceToken {
  id         String    @id @default(uuid())
  residentId String
  tokenHash  String    @unique
  label      String?
  createdAt  DateTime  @default(now())
  lastSeenAt DateTime?
  revokedAt  DateTime?

  resident Resident @relation(fields: [residentId], references: [id], onDelete: Cascade)

  @@index([residentId])
}

model Medication {
  id                   String   @id @default(uuid())
  residentId           String
  name                 String
  dosageLabel          String
  instructionsLabel    String
  prescribingSourceLabel String
  active               Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  resident  Resident             @relation(fields: [residentId], references: [id])
  schedules MedicationSchedule[]
}

model MedicationSchedule {
  id             String    @id @default(uuid())
  medicationId   String
  residentId     String
  timeOfDay      String
  recurrenceRule String
  startDate      DateTime
  endDate        DateTime?
  active         Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  medication     Medication      @relation(fields: [medicationId], references: [id])
  resident       Resident        @relation(fields: [residentId], references: [id])
  reminderEvents ReminderEvent[]
}

model ReminderEvent {
  id                   String              @id @default(uuid())
  residentId           String
  medicationScheduleId String
  scheduledAt          DateTime
  deliveredAt          DateTime?
  status               ReminderStatus
  confirmationSource   ConfirmationSource?
  transcriptSnippet    String?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt

  resident           Resident           @relation(fields: [residentId], references: [id])
  medicationSchedule MedicationSchedule @relation(fields: [medicationScheduleId], references: [id])
}

model Alert {
  id                   String      @id @default(uuid())
  residentId           String
  type                 AlertType
  severity             AlertSeverity
  status               AlertStatus @default(created)
  message              String
  assignedToCaregiverId String?
  createdAt            DateTime    @default(now())
  acknowledgedAt       DateTime?
  resolvedAt           DateTime?

  resident           Resident   @relation(fields: [residentId], references: [id])
  assignedCaregiver  Caregiver? @relation(fields: [assignedToCaregiverId], references: [id])
}

model AuditLog {
  id         String         @id @default(uuid())
  actorType  AuditActorType
  actorId    String?
  action     String
  entityType String
  entityId   String?
  metadata   Json           @default("{}")
  createdAt  DateTime       @default(now())
}

enum ConsentStatus {
  pending
  granted
  revoked
  guardian_granted
}

enum Gender {
  female
  male
  other
  unspecified
}

// Non-medical categories only — keeps the companion memory clear of the medical
// data boundary. No "health"/"diagnosis" category by design.
enum MemoryCategory {
  family
  preference
  life_history
  routine
  other
}

enum CaregiverRole {
  family
  nurse
  facility_staff
  admin
}

enum ReminderStatus {
  scheduled
  delivered
  confirmed_taken
  confirmed_not_taken
  unknown
  missed
  escalated
}

enum ConfirmationSource {
  voice
  caregiver
  dashboard
  manual
}

enum AlertType {
  missed_medication
  medication_uncertainty
  emergency_phrase
  wellbeing_concern
  device_offline
  other
}

enum AlertSeverity {
  low
  medium
  high
  critical
}

enum AlertStatus {
  created
  sent
  acknowledged
  resolved
  failed
}

enum AuditActorType {
  resident
  caregiver
  system
  ai
}
